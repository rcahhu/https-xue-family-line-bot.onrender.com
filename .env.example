APP_NAME=薛家好好玩
PORT=3000
BASE_URL=https://your-domain.example.com

# LINE Developers > Messaging API channel
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token

# LINE Developers > LIFF app
LIFF_ID=your_liff_id

# OpenAI API for real chat-style travel assistant
# Add this in Render only. Do not paste it in LINE chat or GitHub.
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5-mini
OPENAI_ENABLE_WEB_SEARCH=true

# Local fallback for development
STORAGE_BACKEND=json
DATA_FILE=./data/trips.json

# Render Free + Supabase Free settings. Uncomment/fill these in Render Environment.
# STORAGE_BACKEND=supabase
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# SUPABASE_STATE_TABLE=xuebot_state
# SUPABASE_STATE_ID=default
# SUPABASE_STORAGE_BUCKET=xuebot-photos
